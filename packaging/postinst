#!/bin/sh
set -e

# pdn-convers postinst.
#
# This package ships CODE only — the single-file binary + the app manifest — into the packetnet
# SYSTEM app dir /usr/share/packetnet/apps/convers (dpkg creates that dir as it unpacks the payload;
# nothing to do here). All runtime STATE (convers.db, convers.yaml, WAL/SHM sidecars) lives in the
# packetnet OWNER app-state dir /var/lib/packetnet/apps/convers and is NEVER shipped or clobbered by
# this package (see docs/release-pipeline.md for the code-vs-state split).
#
# The packetnet node host package owns the `packetnet` system user and the /var/lib/packetnet root.
# The convers package is a soft Recommends of packetnet, so the user may not exist yet at configure
# time. We therefore only prepare the state dir when the user already exists, and never fail if it
# does not — pdn itself creates the per-app state dir at runtime (packetnet-owned, 0750), so an
# absent dir here is harmless.
#
# Idempotent, and deliberately does NOT (re)start the packetnet service — that is the deploy
# script's job (scripts/deploy-convers.sh) / the node owner's choice.

case "$1" in
  configure)
    if getent passwd packetnet >/dev/null; then
      # Match the node package's per-app state convention: packetnet-owned, 0750.
      install -d -o packetnet -g packetnet -m 0750 /var/lib/packetnet/apps/convers
    fi
    ;;
esac

exit 0
